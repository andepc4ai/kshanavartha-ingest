# Copy this file to run-local.env and fill in your actual values.
# run-local.env is gitignored — never commit it.
#
# Load in PowerShell:
#   Get-Content run-local.env | ForEach-Object {
#       if ($_ -match '^\s*([^#=]+?)\s*=\s*(.*)\s*$') {
#           [System.Environment]::SetEnvironmentVariable($Matches[1], $Matches[2])
#       }
#   }
#
# Then run:  python ingest.py

# ── AI engines (at least one required) ──────────────────────────────────
CEREBRAS_API_KEYS=csk-your-key-here
GEMINI_API_KEYS=AIza-key1,AIza-key2
SAMBANOVA_API_KEYS=sn-key-here

# ── Firebase ─────────────────────────────────────────────────────────────
# Paste the full JSON of your Firebase service account key (one line):
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Cloudflare R2 ─────────────────────────────────────────────────────────
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ── FCM (optional) ────────────────────────────────────────────────────────
# Set to 1 only when real device tokens are registered in Firestore.
FCM_ENABLED=0

# ── Tuning (optional — all have safe code defaults) ───────────────────────
# FIRESTORE_DB_ID=default
# GEMINI_MODEL=gemini-2.0-flash
# MAX_TOTAL_GEMINI=15
# RETENTION_DAYS=14
# FEED_MAX=500
# CINEMA_MAX=8
# NOTIFICATION_GAP_HOURS=3
# AUDIO_MAX_PER_RUN=30

# ── Testing helpers ────────────────────────────────────────────────────────
# LIMIT=2        # process at most 2 new articles per run (saves AI quota)
# DRY_RUN=1      # no Firestore/R2 writes; output goes to dry_run_output.csv
# OLLAMA_MODEL=qwen2.5:3b   # use local Ollama instead of any API
